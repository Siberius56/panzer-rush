damping_min = 0.0
damping_max = 0.0
scale_min = 1.0
scale_max = 1.0
color = Color(1, 1, 1, 1)

[node name="WavePulseEmitter" type="Node3D"]

[node name="GPUParticles3D" type="GPUParticles3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0.04, 0)
cast_shadow = 0
visibility_aabb = AABB(-4.5, -0.25, -4.5, 9, 0.5, 9)
amount = 1
