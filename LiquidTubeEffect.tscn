[sub_resource type="Shader" id="Shader_bubble"]
code = "shader_type spatial;\nrender_mode blend_mix, depth_draw_alpha_prepass, cull_back;\n\nuniform vec4 bubble_color : source_color = vec4(0.78, 1.0, 0.88, 0.28);\n\nvoid fragment() {\n\tfloat rim = pow(1.0 - clamp(dot(NORMAL, VIEW), 0.0, 1.0), 1.7);\n\tALBEDO = bubble_color.rgb;\n\tALPHA = clamp(0.10 + rim * 0.72, 0.0, 0.86);\n\tROUGHNESS = 0.02;\n\tSPECULAR = 0.95;\n\tEMISSION = bubble_color.rgb * rim * 0.22;\n}\n"

