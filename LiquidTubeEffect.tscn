[gd_scene load_steps=12 format=3]

[sub_resource type="Shader" id="Shader_liquid"]
code = "shader_type spatial;\nrender_mode blend_mix, depth_draw_alpha_prepass, cull_disabled;\n\nuniform vec4 liquid_color : source_color = vec4(0.18, 0.85, 0.38, 0.55);\nuniform vec4 light_color : source_color = vec4(0.62, 1.0, 0.70, 0.35);\nuniform float opacity = 0.56;\nuniform float wave_strength = 0.025;\nuniform float wave_speed = 0.75;\nuniform float vertical_flow_speed = 0.16;\nuniform float fresnel_power = 2.2;\n\nfloat hash(vec2 p) {\n\treturn fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453123);\n}\n\nfloat noise(vec2 p) {\n\tvec2 i = floor(p);\n\tvec2 f = fract(p);\n\tvec2 u = f * f * (3.0 - 2.0 * f);\n\treturn mix(mix(hash(i + vec2(0.0, 0.0)), hash(i + vec2(1.0, 0.0)), u.x), mix(hash(i + vec2(0.0, 1.0)), hash(i + vec2(1.0, 1.0)), u.x), u.y);\n}\n\nvoid vertex() {\n\tfloat t = TIME * wave_speed;\n\tfloat n = noise(UV * vec2(13.0, 4.0) + vec2(t, -t * 0.45));\n\tVERTEX.xz += NORMAL.xz * ((n - 0.5) * wave_strength);\n}\n\nvoid fragment() {\n\tfloat t = TIME;\n\tvec2 moving_uv = UV + vec2(sin(UV.y * 9.0 + t * 0.9) * 0.025, -t * vertical_flow_speed);\n\tfloat n1 = noise(moving_uv * vec2(10.0, 6.0));\n\tfloat n2 = noise(moving_uv * vec2(25.0, 16.0) + vec2(0.0, t * 0.25));\n\tfloat currents = smoothstep(0.50, 0.86, n1 * 0.62 + n2 * 0.38);\n\tfloat rim = pow(1.0 - clamp(dot(NORMAL, VIEW), 0.0, 1.0), fresnel_power);\n\tvec3 col = mix(liquid_color.rgb, light_color.rgb, currents * 0.35 + rim * 0.45);\n\tALBEDO = col;\n\tALPHA = clamp(opacity + currents * 0.10 + rim * 0.24, 0.0, 0.92);\n\tROUGHNESS = 0.06;\n\tMETALLIC = 0.0;\n\tSPECULAR = 0.85;\n\tEMISSION = col * (rim * 0.20 + currents * 0.025);\n}\n"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_liquid"]
render_priority = 1
shader = SubResource("Shader_liquid")
shader_parameter/liquid_color = Color(0.18, 0.85, 0.38, 0.55)
shader_parameter/light_color = Color(0.62, 1, 0.7, 0.35)
shader_parameter/opacity = 0.56
shader_parameter/wave_strength = 0.025
shader_parameter/wave_speed = 0.75
shader_parameter/vertical_flow_speed = 0.16
shader_parameter/fresnel_power = 2.2

[sub_resource type="CylinderMesh" id="CylinderMesh_liquid"]
top_radius = 0.42
