height = 2.55
radial_segments = 96
rings = 24

[sub_resource type="Shader" id="Shader_surface"]
code = "shader_type spatial;\nrender_mode blend_mix, depth_draw_alpha_prepass, cull_disabled;\n\nuniform vec4 surface_color : source_color = vec4(0.50, 1.0, 0.60, 0.45);\nuniform float opacity = 0.45;\n\nfloat hash(vec2 p) {\n\treturn fract(sin(dot(p, vec2(41.2, 289.7))) * 85321.13579);\n}\n\nfloat noise(vec2 p) {\n\tvec2 i = floor(p);\n\tvec2 f = fract(p);\n\tvec2 u = f * f * (3.0 - 2.0 * f);\n\treturn mix(mix(hash(i + vec2(0.0, 0.0)), hash(i + vec2(1.0, 0.0)), u.x), mix(hash(i + vec2(0.0, 1.0)), hash(i + vec2(1.0, 1.0)), u.x), u.y);\n}\n\nvoid vertex() {\n\tfloat n = noise(UV * 6.0 + vec2(TIME * 0.25, TIME * 0.15));\n\tVERTEX.y += (n - 0.5) * 0.018;\n}\n\nvoid fragment() {\n\tvec2 p = UV - vec2(0.5);\n\tfloat r = length(p) * 2.0;\n\tfloat circle_mask = smoothstep(1.0, 0.93, r);\n\tfloat ripple = sin(r * 32.0 - TIME * 4.0 + noise(UV * 8.0 + vec2(TIME * 0.2)) * 3.0);\n\tfloat ring = smoothstep(0.40, 1.0, ripple * 0.5 + 0.5);\n\tALBEDO = surface_color.rgb;\n\tALPHA = circle_mask * clamp(opacity + ring * 0.14, 0.0, 0.72);\n\tROUGHNESS = 0.03;\n\tSPECULAR = 0.9;\n\tEMISSION = surface_color.rgb * ring * 0.06;\n}\n"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_surface"]
render_priority = 2
shader = SubResource("Shader_surface")
shader_parameter/surface_color = Color(0.5, 1, 0.6, 0.45)
shader_parameter/opacity = 0.45

