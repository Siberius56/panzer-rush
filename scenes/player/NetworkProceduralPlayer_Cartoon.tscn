[sub_resource type="Shader" id="Shader_PostProcessOutlineV2"]
code = "shader_type spatial;

render_mode unshaded, cull_disabled, depth_test_disabled, fog_disabled;

uniform sampler2D screen_texture : hint_screen_texture, filter_linear_mipmap;
uniform sampler2D depth_texture : hint_depth_texture, filter_nearest;
uniform sampler2D normal_roughness_texture : hint_normal_roughness_texture, filter_nearest;

uniform float edge_width : hint_range(0.5, 5.0) = 1.2;
uniform float depth_threshold : hint_range(0.0001, 0.1) = 0.006;
uniform float normal_threshold : hint_range(0.01, 2.0) = 0.32;
uniform float edge_softness : hint_range(0.01, 2.0) = 0.35;
uniform float edge_strength : hint_range(0.0, 1.0) = 1.0;
uniform vec3 edge_color : source_color = vec3(0.015, 0.01, 0.018);

void vertex() {
	POSITION = vec4(VERTEX.xy, 1.0, 1.0);
}

float get_depth(vec2 uv) {
	return texture(depth_texture, uv).r;
}

vec3 get_normal(vec2 uv) {
	vec3 normal = texture(normal_roughness_texture, uv).xyz;
	normal = normal * 2.0 - 1.0;
	return normalize(normal);
}

void fragment() {
	vec2 uv = SCREEN_UV;
	vec2 pixel_size = edge_width / VIEWPORT_SIZE.xy;

	vec3 base_color = texture(screen_texture, uv).rgb;

	float center_depth = get_depth(uv);
	vec3 center_normal = get_normal(uv);

	float depth_edge = 0.0;
	float normal_edge = 0.0;

	vec2 offsets[8] = vec2[](
		vec2(-1.0, -1.0),
		vec2( 0.0, -1.0),
		vec2( 1.0, -1.0),
		vec2(-1.0,  0.0),
		vec2( 1.0,  0.0),
		vec2(-1.0,  1.0),
		vec2( 0.0,  1.0),
		vec2( 1.0,  1.0)
	);

	for (int i = 0; i < 8; i++) {
		vec2 sample_uv = uv + offsets[i] * pixel_size;

		float sample_depth = get_depth(sample_uv);
		vec3 sample_normal = get_normal(sample_uv);

		float depth_difference = abs(center_depth - sample_depth);
		float normal_difference = distance(center_normal, sample_normal);

		depth_edge = max(depth_edge, depth_difference);
		normal_edge = max(normal_edge, normal_difference);
	}

	float depth_line = smoothstep(depth_threshold, depth_threshold * (1.0 + edge_softness), depth_edge);
	float normal_line = smoothstep(normal_threshold, normal_threshold * (1.0 + edge_softness), normal_edge);
	float edge_mask = clamp(max(depth_line, normal_line), 0.0, 1.0);

	ALBEDO = mix(base_color, edge_color, edge_mask * edge_strength);
	ALPHA = 1.0;
}"

