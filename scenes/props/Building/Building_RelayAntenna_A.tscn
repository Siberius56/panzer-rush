[sub_resource type="Shader" id="Shader_7f44e"]
code = "shader_type spatial;
render_mode unshaded, blend_add, depth_draw_never, cull_disabled;

// Expanding circular wave for GPUParticles3D.
// The animation uses INSTANCE_CUSTOM.y, the particle lifetime phase.

uniform vec4 base_color : source_color = vec4(1.0, 0.42, 0.08, 0.78);
uniform float radius_start = 0.035;
uniform float radius_end = 0.485;
uniform float ring_width = 0.165;
uniform float outer_sharpness = 0.010;
uniform float fade_in = 0.070;
uniform float fade_out_start = 0.700;
uniform float emission_strength = 1.450;
uniform float alpha_strength = 1.000;

varying float particle_phase;

void vertex() {
	particle_phase = INSTANCE_CUSTOM.y;
}

void fragment() {
	vec2 centered_uv = UV - vec2(0.5);
	float dist_from_center = length(centered_uv);

	float phase = clamp(particle_phase, 0.0, 1.0);
	float progress = smoothstep(0.0, 1.0, phase);
	float radius = mix(radius_start, radius_end, progress);

	// Sharp outside edge.
	float outer_mask = 1.0 - smoothstep(radius - outer_sharpness, radius + outer_sharpness, dist_from_center);

	// Interior fades toward the center.
	float inner_gradient = smoothstep(radius - ring_width, radius, dist_from_center);
	inner_gradient = pow(inner_gradient, 1.55);

	// Lifetime fade. Appears from center, then fades before the next pulse.
	float appear = smoothstep(0.0, fade_in, phase);
	float disappear = 1.0 - smoothstep(fade_out_start, 1.0, phase);
	float life_alpha = appear * disappear;

	float alpha = clamp(outer_mask * inner_gradient * life_alpha * base_color.a * alpha_strength, 0.0, 1.0);

	ALBEDO = base_color.rgb;
	EMISSION = base_color.rgb * emission_strength * alpha;
	ALPHA = alpha;
}
"

