[sub_resource type="Shader" id="Shader_bubble"]
code = "shader_type spatial;
render_mode blend_mix, depth_prepass_alpha, cull_back;

uniform vec4 bubble_color : source_color = vec4(0.78, 1.0, 0.88, 0.28);

void fragment() {
	float rim = pow(1.0 - clamp(dot(NORMAL, VIEW), 0.0, 1.0), 1.7);
	ALBEDO = bubble_color.rgb;
	ALPHA = clamp(0.10 + rim * 0.72, 0.0, 0.86);
	ROUGHNESS = 0.02;
	SPECULAR = 0.95;
	EMISSION = bubble_color.rgb * rim * 0.22;
}
"

