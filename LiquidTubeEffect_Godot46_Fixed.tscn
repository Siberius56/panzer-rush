[sub_resource type="Shader" id="Shader_v12j7"]
code = "shader_type spatial;
render_mode blend_mix, depth_prepass_alpha, cull_disabled;

uniform vec4 surface_color : source_color = vec4(0.50, 1.0, 0.60, 0.45);
uniform float opacity = 0.45;

float hash(vec2 p) {
	return fract(sin(dot(p, vec2(41.2, 289.7))) * 85321.13579);
}

float noise(vec2 p) {
	vec2 i = floor(p);
	vec2 f = fract(p);
	vec2 u = f * f * (3.0 - 2.0 * f);
	return mix(mix(hash(i + vec2(0.0, 0.0)), hash(i + vec2(1.0, 0.0)), u.x), mix(hash(i + vec2(0.0, 1.0)), hash(i + vec2(1.0, 1.0)), u.x), u.y);
}

void vertex() {
	float n = noise(UV * 6.0 + vec2(TIME * 0.25, TIME * 0.15));
	VERTEX.y += (n - 0.5) * 0.018;
}

void fragment() {
	vec2 p = UV - vec2(0.5);
	float r = length(p) * 2.0;
	float circle_mask = smoothstep(1.0, 0.93, r);
	float ripple = sin(r * 32.0 - TIME * 4.0 + noise(UV * 8.0 + vec2(TIME * 0.2)) * 3.0);
	float ring = smoothstep(0.40, 1.0, ripple * 0.5 + 0.5);
	ALBEDO = surface_color.rgb;
	ALPHA = circle_mask * clamp(opacity + ring * 0.14, 0.0, 0.72);
	ROUGHNESS = 0.03;
	SPECULAR = 0.9;
	EMISSION = surface_color.rgb * ring * 0.06;
}
"

