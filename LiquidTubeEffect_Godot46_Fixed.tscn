[sub_resource type="Shader" id="Shader_tu21i"]
code = "shader_type spatial;
render_mode blend_mix, depth_prepass_alpha, cull_disabled;

uniform vec4 liquid_color : source_color = vec4(0.18, 0.85, 0.38, 0.55);
uniform vec4 light_color : source_color = vec4(0.62, 1.0, 0.70, 0.35);
uniform float opacity = 0.56;
uniform float wave_strength = 0.025;
uniform float wave_speed = 0.75;
uniform float vertical_flow_speed = 0.16;
uniform float fresnel_power = 2.2;

float hash(vec2 p) {
	return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453123);
}

float noise(vec2 p) {
	vec2 i = floor(p);
	vec2 f = fract(p);
	vec2 u = f * f * (3.0 - 2.0 * f);
	return mix(mix(hash(i + vec2(0.0, 0.0)), hash(i + vec2(1.0, 0.0)), u.x), mix(hash(i + vec2(0.0, 1.0)), hash(i + vec2(1.0, 1.0)), u.x), u.y);
}

void vertex() {
	float t = TIME * wave_speed;
	float n = noise(UV * vec2(13.0, 4.0) + vec2(t, -t * 0.45));
	VERTEX.xz += NORMAL.xz * ((n - 0.5) * wave_strength);
}

void fragment() {
	float t = TIME;
	vec2 moving_uv = UV + vec2(sin(UV.y * 9.0 + t * 0.9) * 0.025, -t * vertical_flow_speed);
	float n1 = noise(moving_uv * vec2(10.0, 6.0));
	float n2 = noise(moving_uv * vec2(25.0, 16.0) + vec2(0.0, t * 0.25));
	float currents = smoothstep(0.50, 0.86, n1 * 0.62 + n2 * 0.38);
	float rim = pow(1.0 - clamp(dot(NORMAL, VIEW), 0.0, 1.0), fresnel_power);
	vec3 col = mix(liquid_color.rgb, light_color.rgb, currents * 0.35 + rim * 0.45);
	ALBEDO = col;
	ALPHA = clamp(opacity + currents * 0.10 + rim * 0.24, 0.0, 0.92);
	ROUGHNESS = 0.06;
	METALLIC = 0.0;
	SPECULAR = 0.85;
	EMISSION = col * (rim * 0.20 + currents * 0.025);
}
"

