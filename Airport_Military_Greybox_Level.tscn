[node name="Zone1_Title" type="Label3D" parent="09_Annotations_Text" unique_id=552381684]
transform = Transform3D(1, 0, 0, 0, -4.371139e-08, 1, 0, -1, -4.371139e-08, 0, 7, 170)
pixel_size = 0.065
text = "ZONE 1 - AUTOROUTE ÉLEVÉE
Rythme: conduite, collisions, esquive, voitures à pousser.
Objectif: quitter l’autoroute par une sortie descendante vers l’aéroport."
font_size = 38
outline_size = 8
width = 1400.0

[node name="Start_Label" type="Label3D" parent="09_Annotations_Text" unique_id=1928007870]
transform = Transform3D(1, 0, 0, 0, -4.371139e-08, 1, 0, -1, -4.371139e-08, 0, 7.2, 185)
pixel_size = 0.065
modulate = Color(1, 0.9, 0.4, 1)
text = "SPAWN: autoroute barricadée, véhicules abandonnés, entrée sous pression."
font_size = 30
outline_size = 8
width = 1000.0

[node name="Z1_Pileup_Label" type="Label3D" parent="09_Annotations_Text" unique_id=378021987]
transform = Transform3D(1, 0, 0, 0, -4.371139e-08, 1, 0, -1, -4.371139e-08, 0, 7.4, 70)
pixel_size = 0.065
text = "Obstacle principal: carambolage.
