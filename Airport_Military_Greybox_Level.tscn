[node name="DesignNote_MainFlow" type="Label3D" parent="09_Annotations_Text" unique_id=782704982]
transform = Transform3D(1, 0, 0, 0, -4.371139e-08, 1, 0, -1, -4.371139e-08, 0, 2.3, 72)
pixel_size = 0.065
text = "Structure de flow: Zone 1 = déplacement forcé et chaos contrôlé. Zone 2 = hub de tarmac plus ouvert. Zone 3 = piste militaire, lignes de vue longues, préparation du boss."
font_size = 25
outline_size = 8
width = 1900.0

[node name="DesignNote_Coop" type="Label3D" parent="09_Annotations_Text" unique_id=1771377825]
transform = Transform3D(1, 0, 0, 0, -4.371139e-08, 1, 0, -1, -4.371139e-08, 0, 2.3, -64)
pixel_size = 0.065
text = "Coop conseillé: éviter les tâches solo longues. Préférer des actions parallèles courtes: tenir une console, protéger le véhicule, remorquer, pousser, ouvrir une porte."
font_size = 25
outline_size = 8
width = 1900.0

[node name="DesignNote_Vehicle" type="Label3D" parent="09_Annotations_Text" unique_id=59166630]
