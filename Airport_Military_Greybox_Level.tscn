font_size = 28
outline_size = 8
width = 1000.0

[node name="Z1_Foot_Explore_Label" type="Label3D" parent="09_Annotations_Text" unique_id=463229809]
transform = Transform3D(1, 0, 0, 0, -4.371139e-08, 1, 0, -1, -4.371139e-08, -45, 7, 128)
pixel_size = 0.065
modulate = Color(0.45, 0.9, 1, 1)
text = "Exploration à pied: passerelle de service.
Récompense possible: caisse, raccourci, terminal qui baisse une barrière."
font_size = 26
outline_size = 8
width = 850.0

[node name="Z1_Ramp_Label" type="Label3D" parent="09_Annotations_Text" unique_id=1068527733]
transform = Transform3D(1, 0, 0, 0, -4.371139e-08, 1, 0, -1, -4.371139e-08, 50, 4, 61)
pixel_size = 0.065
text = "Sortie d’autoroute: rupture de rythme.
Le véhicule descend au sol, entrée dans la base militaire."
font_size = 28
outline_size = 8
width = 900.0

[node name="Puzzle_A_Text" type="Label3D" parent="09_Annotations_Text" unique_id=232188201]
transform = Transform3D(1, 0, 0, 0, -4.371139e-08, 1, 0, -1, -4.371139e-08, 53, 7, 90)
pixel_size = 0.065
modulate = Color(0.4, 1, 0.4, 1)
text = "ÉNIGME A: dégager la sortie.
Pousser 3 voitures dans les glissières pour libérer la rampe.
Variante: un joueur active une dépanneuse pendant que le conducteur pousse."
font_size = 26
outline_size = 8
width = 1000.0

[node name="PG01_Label" type="Label3D" parent="09_Annotations_Text" unique_id=2042159804]
transform = Transform3D(1, 0, 0, 0, -4.371139e-08, 1, 0, -1, -4.371139e-08, 14, 3.6, 36)
pixel_size = 0.065
modulate = Color(1, 0.18, 0.12, 1)
text = "PASSAGE GATE 01
Tous les joueurs requis.
No return: l’autoroute se ferme derrière."
outline_size = 8
width = 900.0

[node name="Zone2_Title" type="Label3D" parent="09_Annotations_Text" unique_id=1307045741]
transform = Transform3D(1, 0, 0, 0, -4.371139e-08, 1, 0, -1, -4.371139e-08, 0, 3, 48)
pixel_size = 0.065
text = "ZONE 2 - ENTRÉE DE L’AÉROPORT MILITAIRE
Rythme: grande respiration après l’autoroute.
Contenu: checkpoint, hangars simples, tarmac, avions stationnés, tour de contrôle, puzzles latéraux."
font_size = 36
outline_size = 8
width = 1600.0

[node name="Hangar_A_Label" type="Label3D" parent="09_Annotations_Text" unique_id=557655067]
transform = Transform3D(1, 0, 0, 0, -4.371139e-08, 1, 0, -1, -4.371139e-08, -58, 5.7, 9)
pixel_size = 0.065
text = "HANGAR A
Entrable. Bon lieu pour combat serré.
Peut cacher un générateur ou une clé de piste."
font_size = 24
outline_size = 8
width = 800.0

[node name="Hangar_B_Label" type="Label3D" parent="09_Annotations_Text" unique_id=530933920]
transform = Transform3D(1, 0, 0, 0, -4.371139e-08, 1, 0, -1, -4.371139e-08, 68, 5.7, -18)
pixel_size = 0.065
text = "HANGAR B
Intérieur large pour véhicule.
Idée: porte lourde ouverte par câble remorqué."
font_size = 24
outline_size = 8
width = 800.0

[node name="ControlTower_Label" type="Label3D" parent="09_Annotations_Text" unique_id=1890381090]
transform = Transform3D(1, 0, 0, 0, -4.371139e-08, 1, 0, -1, -4.371139e-08, -78, 19, -38)
pixel_size = 0.065
modulate = Color(0.5, 0.9, 1, 1)
text = "TOUR DE CONTRÔLE
Exploration verticale à pied.
Permet de repérer le chemin et de déclencher une porte à distance."
font_size = 24
outline_size = 8
width = 850.0

[node name="FuelDepot_Label" type="Label3D" parent="09_Annotations_Text" unique_id=258136087]
